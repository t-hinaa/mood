    <p class="text-gray-500 text-center mb-6 leading-relaxed">
      その日の色をタップするだけ。言葉にできない思いも大切にします。
    </p>
    
    <!-- カードを横並びにするコンテナ -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      
      <!-- カード1 -->
