<!-- 波線の区切り -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" class="w-full">
  <path fill="#FFEEF0" fill-opacity="1" d="M0,128L60,149.3C120,171,240,213,360,229.3C480,245,600,235,720,202.7C840,171,960,117,1080,117.3C1200,117,1320,171,1380,197.3L1440,224L1440,0L1380,0C1320,0,1200,0,1080,0C960,0,840,0,720,0C600,0,480,0,360,0C240,0,120,0,60,0L0,0Z"></path>
</svg>


<!-- 特徴セクション -->
<div class="py-20 bg-[#FFFDFD]">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-gray-600">4つの特徴</h2>
    
    <div class="grid md:grid-cols-4 gap-8">
      <!-- 特徴1 -->
      <div class="text-center p-6 rounded-lg hover:shadow-lg transition duration-300">
        <div class="h-32 overflow-hidden">
          <%= image_tag "iphone.png", class: "w-full h-full object-contain" %>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-600">すぐに始められる</h3>
        <p class="text-gray-500">登録不要。今すぐ気分の記録を開始できます</p>
      </div>

      <!-- 特徴2 -->
      <div class="text-center p-6 rounded-lg hover:shadow-lg transition duration-300">
        <div class="h-32 overflow-hidden">
          <%= image_tag "bookmarker.png", class: "w-full h-full object-contain" %>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-600">手始めに</h3>
        <p class="text-gray-500">日記やジャーナリングを始める第一歩になります</p>
      </div>
      
      <!-- 特徴3 -->
      <div class="text-center p-6 rounded-lg hover:shadow-lg transition duration-300">
        <div class="h-32 overflow-hidden">
          <%= image_tag "book.png", class: "w-full h-full object-contain" %>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-600">視覚的に確認</h3>
        <p class="text-gray-500">カレンダーで気分の変化を一目で把握できます</p>
      </div>
      
      <!-- 特徴4 -->
      <div class="text-center p-6 rounded-lg hover:shadow-lg transition duration-300">
        <div class="h-32 overflow-hidden">
          <%= image_tag "heart.png", class: "w-full h-full object-contain" %>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-600">プライベート</h3>
        <p class="text-gray-500">あなたのデータは安全に保管されます</p>
      </div>
    </div>
  </div>
</div>

<!-- フッター -->
<footer class="bg-gray-50 py-8">
  <div class="max-w-6xl mx-auto px-4 text-center text-gray-600">
    <p>&copy; 2026 Mood Tracker</p>
  </div>
</footer>

