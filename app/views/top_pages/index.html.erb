<!-- ヒーローセクション -->
<div class="min-h-screen bg-gradient-to-t from-[#FFEEF0] to-[#F7D8DC] flex items-center justify-center px-4">
  <div class="max-w-4xl mx-auto text-center">
    <!-- キャッチコピー -->
    <h1 class="text-6xl md:text-5xl font-bold text-gray-600 mb-12">
      私だけの気分管理ツール
    </h1>
    
    <!-- サブコピー -->
    <p class="text-xl text-gray-600 mb-14 leading-relaxed">
      やってみたいなの気持ちだけで十分！<br>
      忘れる日があってもいい！<br>
      日記やジャーナリングは続けられるか自信のない方へ。
    </p>
    
    <!-- CTA ボタン -->
    <a href="/moods/new" class="inline-block bg-[#EE9CA7] hover:bg-[#4e8098] text-white font-bold py-4 px-8 rounded-full text-lg transition duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1">
      ログイン不要で今すぐ記録を始める →
    </a>
  </div>
</div>


<!-- 横並びカードセクション -->
