          </svg>
          <p class="text-sm font-bold text-gray-600 mt-2">驚き</h>
        </div>
      </div>

      <!-- カード5 -->
      <div class="flex flex-col items-center">
        <div class="w-40 h-40 bg-[#FFFDFD] rounded-full flex flex-col items-center justify-center shadow-lg
                    hover:scale-110 hover:shadow-2xl hover:-translate-y-2
                    transition-all duration-300 ease-out cursor-pointer">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"class="w-20 h-20">
